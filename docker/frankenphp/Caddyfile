{
	frankenphp
}

:80 {
	root /app/public
	encode zstd br gzip

	@static {
		path /uploads/* /assets/* /bundles/*
		path *.ico *.css *.js *.webp *.jpeg *.jpg *.png *.gif *.svg *.woff2
	}
	header @static Cache-Control "public, max-age=31536000, immutable"

	@phpRoute {
		not file {path}
	}
	rewrite @phpRoute index.php

	php {
		root /app/public
	}

	file_server {
		hide *.php
	}
}
