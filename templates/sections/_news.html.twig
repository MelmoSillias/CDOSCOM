<section id="news" class="py-20 bg-blue-50">
    <div class="container mx-auto px-6 md:px-12">
        <div class="text-center mb-16">
            <h2 class="text-3xl font-bold text-blue-900 mb-4">Actualités</h2>
            <p class="text-gray-600 max-w-2xl mx-auto">Restez informés des dernières nouvelles de notre cabinet.</p>
        </div>
        {% set featured = actualites|default([]) %}
        {% set firstNews = featured|first %}
        <div class="flex flex-col lg:flex-row gap-8">
            <div class="lg:w-2/3">
                <div class="relative bg-white rounded-xl shadow-lg overflow-hidden">
                    <div id="news-carousel" class="relative w-full m-0" data-carousel="slide">
                        <div class="relative h-[520px] overflow-hidden rounded-lg">
                            {% for item in featured %}
                                <div class="{{ loop.first ? 'duration-700 ease-in-out' : 'hidden duration-700 ease-in-out' }}" data-carousel-item="{{ loop.first ? 'active' : '' }}">
                                    <div class="flex flex-col">
                                        <img src="{{ item.image }}" alt="{{ item.titre }}" class="w-full h-64 md:h-80 object-cover">
                                        <div class="p-6">
                                            <span class="text-blue-600 text-sm">{{ item.datePublication|date('d/m/Y H:i') }}</span>
                                            <h3 class="text-xl font-bold text-blue-900 my-2">{{ item.titre }}</h3>
                                            <p class="text-gray-600">{{ item.contenu|striptags|slice(0, 180) ~ (item.contenu|striptags|length > 180 ? '...' : '') }}</p>
                                            <div class="mt-3">
                                                <a href="{{ path('news_show', { slug: item.slug }) }}" class="inline-flex items-center px-4 py-2 rounded-lg bg-blue-50 text-blue-800 font-semibold border border-blue-100 hover:bg-blue-800 hover:text-white transition shadow-sm">Voir</a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            {% else %}
                                <div class="duration-700 ease-in-out" data-carousel-item="active">
                                    <div class="h-64 md:h-80 flex items-center justify-center p-6 text-gray-600">Aucune actualite publiee pour le moment.</div>
                                </div>
                            {% endfor %}
                        </div>

                        <button type="button" class="absolute top-1/2 left-4 z-30 flex items-center justify-center w-10 h-10 bg-white rounded-full shadow-md hover:bg-blue-100 transition" data-carousel-prev>
                            <i class="fas fa-chevron-left text-blue-800"></i>
                        </button>
                        <button type="button" class="absolute top-1/2 right-4 z-30 flex items-center justify-center w-10 h-10 bg-white rounded-full shadow-md hover:bg-blue-100 transition" data-carousel-next>
                            <i class="fas fa-chevron-right text-blue-800"></i>
                        </button>
                    </div>
                </div>
            </div>
            <div class="lg:w-1/3 flex flex-col">
                <div class="bg-white rounded-xl shadow-lg overflow-hidden flex-1 flex flex-col">
                    <img src="{{ asset('assets/img/secretaire.jpeg') }}" alt="Notre secrétaire" class="w-full h-64 object-cover">
                    <div class="p-6 flex-1 flex flex-col">
                        <div class="relative -mt-16 mb-4">
                            <div class="inline-block bg-blue-800 text-white px-4 py-2 rounded-lg">
                                <h3 class="font-bold text-lg"><small>Mlle </small>Mariam Fatoumata SELLOU</h3>
                                <p class="text-sm">Secrétaire</p>
                            </div>
                        </div>
                        <p class="text-gray-600 mb-6">Fatoumata est votre interlocutrice privilégiée pour toute question administrative ou pour prendre rendez-vous. N'hésitez pas à la contacter pour organiser votre visite.</p>
                        <div class="mt-auto">
                            <a href="{{ path('news_index') }}" class="block text-center bg-blue-800 text-white px-6 py-3 rounded-lg font-medium hover:bg-blue-900 transition shadow">Voir toutes les actualités</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
