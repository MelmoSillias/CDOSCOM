<section id="contact" class="py-20 bg-blue-50">
    <div class="container mx-auto px-6 md:px-12">
        <div class="text-center mb-16">
            <h2 class="text-3xl font-bold text-blue-900 mb-4">Contactez-nous</h2>
            <p class="text-gray-600 max-w-2xl mx-auto">Nous sommes à votre écoute pour toute question ou information.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <div class="bg-white rounded-xl shadow-md p-8 animate-fadeIn">
                <h3 class="text-xl font-semibold text-blue-800 mb-6">Coordonnées</h3>
                <div class="space-y-6">
                    <div class="flex items-start">
                        <div class="w-10 h-10 bg-blue-100 rounded-full flex items-center justify-center mr-4 mt-1">
                            <i class="fas fa-phone text-blue-800"></i>
                        </div>
                        <div>
                            <p class="font-medium text-gray-800">Téléphone</p>
                            <p class="text-gray-600">+223 84 07 55 18 / +223 44 56 94 39</p>
                        </div>
                    </div>
                    <div class="flex items-start">
                        <div class="w-10 h-10 bg-blue-100 rounded-full flex items-center justify-center mr-4 mt-1">
                            <i class="fas fa-envelope text-blue-800"></i>
                        </div>
                        <div>
                            <p class="font-medium text-gray-800">Email</p>
                            <p class="text-gray-600">contact@cdos-dentaire.fr</p>
                        </div>
                    </div>
                    <div class="flex items-start">
                        <div class="w-10 h-10 bg-blue-100 rounded-full flex items-center justify-center mr-4 mt-1">
                            <i class="fas fa-map-marker-alt text-blue-800"></i>
                        </div>
                        <div>
                            <p class="font-medium text-gray-800">Adresse</p>
                            <p class="text-gray-600">À 100m du feu de Garantiguibougou<br>en face de la voie de Garantiguibougou <br> Rue: 426, Estée 192</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="bg-white rounded-xl shadow-md p-8 md:col-span-2 animate-fadeIn delay-200">
                <h3 class="text-xl font-semibold text-blue-800 mb-6">Envoyez-nous un message</h3>
                <form id="contact-form" class="space-y-4">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label for="contact-name" class="block text-gray-700 mb-2">Nom</label>
                            <input type="text" id="contact-name" name="name" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" required>
                        </div>
                        <div>
                            <label for="contact-email" class="block text-gray-700 mb-2">Email</label>
                            <input type="email" id="contact-email" name="email" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" required>
                        </div>
                    </div>
                    <div>
                        <label for="contact-subject" class="block text-gray-700 mb-2">Sujet</label>
                        <input type="text" id="contact-subject" name="subject" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" required>
                    </div>
                    <div>
                        <label for="contact-message" class="block text-gray-700 mb-2">Message</label>
                        <textarea id="contact-message" name="message" rows="4" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" required></textarea>
                    </div>
                    <button type="submit" class="bg-blue-800 text-white px-6 py-3 rounded-lg font-medium hover:bg-blue-900 transition">Envoyer le message</button>
                </form>
            </div>
        </div>

        <div class="mt-16 text-center animate-fadeIn delay-400">
            <h3 class="text-xl font-semibold text-blue-800 mb-6">Suivez-nous sur les réseaux sociaux</h3>
            <div class="flex justify-center space-x-6">
                <a href="#" class="w-12 h-12 bg-blue-800 text-white rounded-full flex items-center justify-center hover:bg-blue-900 transition">
                    <i class="fab fa-facebook-f text-xl"></i>
                </a>
                <a href="#" class="w-12 h-12 bg-red-800 text-white rounded-full flex items-center justify-center hover:bg-blue-900 transition">
                    <i class="fab fa-instagram text-xl"></i>
                </a>
                <a href="#" class="w-12 h-12 bg-sky-800 text-white rounded-full flex items-center justify-center hover:bg-blue-900 transition">
                    <i class="fab fa-linkedin-in text-xl"></i>
                </a>
                <a href="https://www.tiktok.com/discover/cabinet-dentaire-%C3%A0-bamako?is_from_webapp=1&sender_device=pc" class="w-12 h-12 bg-gray-900 text-white rounded-full flex items-center justify-center hover:bg-blue-900 transition">
                    <i class="fab fa-tiktok text-xl"></i>
                </a>
                <a href="#" class="w-12 h-12 bg-green-800 text-white rounded-full flex items-center justify-center hover:bg-blue-900 transition">
                    <i class="fab fa-whatsapp text-xl"></i>
                </a>
            </div>
        </div>
    </div>
</section>

<!-- Modal de confirmation -->
<div id="contact-modal" class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50 hidden">
    <div class="bg-white rounded-xl p-8 max-w-md w-full mx-4">
        <div class="text-center">
            <div id="modal-icon" class="w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4">
                <!-- Icon will be set by JS -->
            </div>
            <h3 id="modal-title" class="text-xl font-bold mb-2"></h3>
            <p id="modal-message" class="text-gray-600 mb-6"></p>
            <button id="contact-close-modal" class="bg-blue-800 text-white px-6 py-2 rounded-lg font-medium hover:bg-blue-900 transition">Fermer</button>
        </div>
    </div>
</div>

<script>
document.getElementById('contact-form').addEventListener('submit', function(e) {
    e.preventDefault();

    const formData = new FormData(this);
    const data = {
        type: 'contact',
        name: formData.get('name'),
        email: formData.get('email'),
        subject: formData.get('subject'),
        message: formData.get('message')
    };

    // Validation côté client
    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if (!emailRegex.test(data.email)) {
        showModal('error', 'Erreur', 'Veuillez entrer une adresse email valide.');
        return;
    }

    if (!data.name.trim() || !data.subject.trim() || !data.message.trim()) {
        showModal('error', 'Erreur', 'Tous les champs sont obligatoires.');
        return;
    }

    // Envoyer à l'API
    fetch('/api/messages', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
        },
        body: JSON.stringify(data)
    })
    .then(response => response.json())
    .then(result => {
        if (result.error) {
            showModal('error', 'Erreur d\'envoi', result.error);
        } else {
            showModal('success', 'Message envoyé!', result.message);
            this.reset();
        }
    })
    .catch(error => {
        showModal('error', 'Erreur', 'Une erreur s\'est produite. Veuillez réessayer.');
    });
});

function showModal(type, title, message) {
    const modal = document.getElementById('contact-modal');
    const icon = document.getElementById('modal-icon');
    const titleEl = document.getElementById('modal-title');
    const messageEl = document.getElementById('modal-message');

    if (type === 'success') {
        icon.innerHTML = '<i class="fas fa-check text-green-600 text-2xl"></i>';
        icon.className = 'w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4';
    } else {
        icon.innerHTML = '<i class="fas fa-times text-red-600 text-2xl"></i>';
        icon.className = 'w-16 h-16 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-4';
    }

    titleEl.textContent = title;
    messageEl.textContent = message;
    modal.classList.remove('hidden');
}

document.getElementById('contact-close-modal').addEventListener('click', function() {
    document.getElementById('contact-modal').classList.add('hidden');
});
</script>
