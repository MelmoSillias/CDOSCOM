{% extends 'layout.html.twig' %}

{% block title %}Personnels - {{ parent() }}{% endblock %}

{% block body %}
<div class="p-6 space-y-6">
    <div class="flex items-center justify-between">
        <h1 class="text-2xl font-bold text-slate-900">Gestion des personnels</h1>
        <button id="open-create-personnel" class="bg-blue-600 text-white px-4 py-2 rounded-xl shadow hover:bg-blue-700">Nouveau personnel</button>
    </div>

    <div class="bg-white rounded-2xl shadow-md overflow-hidden border border-slate-200">
        <table class="w-full text-left" id="personnels-table">
            <thead class="bg-gradient-to-r from-blue-50 to-cyan-50 text-slate-700">
                <tr>
                    <th class="px-4 py-3 font-semibold">Nom</th>
                    <th class="px-4 py-3 font-semibold">Prenom</th>
                    <th class="px-4 py-3 font-semibold">Poste</th>
                    <th class="px-4 py-3 font-semibold">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100"></tbody>
        </table>
    </div>
</div>

<div id="personnel-modal" class="hidden fixed inset-0 bg-black/50 z-50 items-center justify-center p-4">
    <div class="bg-white rounded-2xl shadow-2xl border border-slate-200 w-full max-w-2xl p-6 max-h-[90vh] overflow-y-auto">
        <h2 id="personnel-modal-title" class="text-xl font-semibold mb-4 text-slate-900">Nouveau personnel</h2>
        <form id="personnel-form" class="space-y-4">
            <input type="hidden" id="personnel-id">
            <div class="grid md:grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm mb-1 text-slate-700">Nom</label>
                    <input id="personnel-nom" class="w-full border border-slate-300 rounded-xl px-3 py-2 focus:ring-2 focus:ring-blue-300 focus:border-blue-500" required>
                </div>
                <div>
                    <label class="block text-sm mb-1 text-slate-700">Prenom</label>
                    <input id="personnel-prenom" class="w-full border border-slate-300 rounded-xl px-3 py-2 focus:ring-2 focus:ring-blue-300 focus:border-blue-500" required>
                </div>
                <div>
                    <label class="block text-sm mb-1 text-slate-700">Poste</label>
                    <input id="personnel-poste" class="w-full border border-slate-300 rounded-xl px-3 py-2 focus:ring-2 focus:ring-blue-300 focus:border-blue-500" required>
                </div>
                <div>
                    <label class="block text-sm mb-1 text-slate-700">Photo</label>
                    <input type="file" id="personnel-photo-file" accept="image/*" class="w-full border border-dashed border-slate-300 rounded-xl px-3 py-2 bg-slate-50" />
                    <input type="hidden" id="personnel-photo" required>
                </div>
            </div>
            <img id="personnel-photo-preview" alt="Apercu photo personnel" class="hidden h-32 w-32 rounded-xl border border-slate-200 object-cover" />
            <div>
                <label class="block text-sm mb-1 text-slate-700">Description</label>
                <textarea id="personnel-description" class="w-full border border-slate-300 rounded-xl px-3 py-2 focus:ring-2 focus:ring-blue-300 focus:border-blue-500" rows="4" required></textarea>
            </div>
            <div class="grid md:grid-cols-3 gap-4">
                <div>
                    <label class="block text-sm mb-1 text-slate-700">LinkedIn</label>
                    <input id="personnel-linkedin" class="w-full border border-slate-300 rounded-xl px-3 py-2 focus:ring-2 focus:ring-blue-300 focus:border-blue-500">
                </div>
                <div>
                    <label class="block text-sm mb-1 text-slate-700">Twitter</label>
                    <input id="personnel-twitter" class="w-full border border-slate-300 rounded-xl px-3 py-2 focus:ring-2 focus:ring-blue-300 focus:border-blue-500">
                </div>
                <div>
                    <label class="block text-sm mb-1 text-slate-700">Facebook</label>
                    <input id="personnel-facebook" class="w-full border border-slate-300 rounded-xl px-3 py-2 focus:ring-2 focus:ring-blue-300 focus:border-blue-500">
                </div>
            </div>
            <div class="flex justify-end gap-2 pt-2">
                <button type="button" id="close-personnel-modal" class="px-4 py-2 rounded-xl bg-slate-200 text-slate-700 hover:bg-slate-300">Annuler</button>
                <button type="submit" class="px-4 py-2 rounded-xl bg-blue-600 text-white hover:bg-blue-700 shadow">Enregistrer</button>
            </div>
        </form>
    </div>
</div>

<div id="delete-personnel-modal" class="hidden fixed inset-0 bg-black/50 z-50 items-center justify-center p-4">
    <div class="bg-white rounded-xl shadow-lg w-full max-w-md p-6">
        <h2 class="text-xl font-semibold mb-3">Supprimer ce personnel ?</h2>
        <p class="text-gray-600 mb-4">Cette action est irreversible.</p>
        <div class="flex justify-end gap-2">
            <button id="cancel-delete-personnel" class="px-4 py-2 rounded bg-gray-200">Annuler</button>
            <button id="confirm-delete-personnel" class="px-4 py-2 rounded bg-red-600 text-white">Supprimer</button>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script src="{{ asset('assets/js/admin_personnels.js') }}"></script>
{% endblock %}
