{% extends 'layout.html.twig' %}

{% block title %}Actualites - {{ parent() }}{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link href="https://cdn.jsdelivr.net/npm/quill@1.3.7/dist/quill.snow.css" rel="stylesheet">
{% endblock %}

{% block body %}
<div class="p-6 space-y-6">
    <div class="flex items-center justify-between">
        <h1 class="text-2xl font-bold text-slate-900">Gestion des actualites</h1>
        <button id="open-create-news" class="bg-blue-600 text-white px-4 py-2 rounded-xl shadow hover:bg-blue-700">Nouvelle actualite</button>
    </div>

    <div class="bg-white rounded-2xl shadow-md overflow-hidden border border-slate-200">
        <table class="w-full text-left" id="actualites-table">
            <thead class="bg-gradient-to-r from-blue-50 to-cyan-50 text-slate-700">
                <tr>
                    <th class="px-4 py-3 font-semibold">Titre</th>
                    <th class="px-4 py-3 font-semibold">Date publication</th>
                    <th class="px-4 py-3 font-semibold">Delai publication</th>
                    <th class="px-4 py-3 font-semibold">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100"></tbody>
        </table>
    </div>
</div>

<div id="news-modal" class="hidden fixed inset-0 bg-black/50 z-50 items-center justify-center p-4">
    <div class="bg-white rounded-2xl shadow-2xl border border-slate-200 w-full max-w-3xl p-6 max-h-[90vh] overflow-y-auto">
        <h2 id="news-modal-title" class="text-xl font-semibold mb-4 text-slate-900">Nouvelle actualite</h2>
        <form id="news-form" class="space-y-4">
            <input type="hidden" id="news-id">
            <div class="grid md:grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm mb-1 text-slate-700">Titre</label>
                    <input id="news-titre" class="w-full border border-slate-300 rounded-xl px-3 py-2 focus:ring-2 focus:ring-blue-300 focus:border-blue-500" required>
                </div>
                <div>
                    <label class="block text-sm mb-1 text-slate-700">Slug (optionnel)</label>
                    <input id="news-slug" class="w-full border border-slate-300 rounded-xl px-3 py-2 focus:ring-2 focus:ring-blue-300 focus:border-blue-500">
                </div>
                <div>
                    <label class="block text-sm mb-1 text-slate-700">Date de publication</label>
                    <input type="datetime-local" id="news-date-publication" class="w-full border border-slate-300 rounded-xl px-3 py-2 focus:ring-2 focus:ring-blue-300 focus:border-blue-500" required>
                </div>
                <div>
                    <label class="block text-sm mb-1 text-slate-700">Delai de publication</label>
                    <input type="datetime-local" id="news-delai-publication" class="w-full border border-slate-300 rounded-xl px-3 py-2 focus:ring-2 focus:ring-blue-300 focus:border-blue-500" required>
                </div>
            </div>
            <div>
                <label class="block text-sm mb-1 text-slate-700">Image</label>
                <input type="file" id="news-image-file" accept="image/*" class="w-full border border-dashed border-slate-300 rounded-xl px-3 py-2 bg-slate-50" />
                <input type="hidden" id="news-image" required>
                <img id="news-image-preview" alt="Apercu image actualite" class="mt-3 hidden h-32 w-full object-cover rounded-xl border border-slate-200" />
            </div>
            <div>
                <label class="block text-sm mb-1 text-slate-700">Contenu</label>
                <div id="news-editor" class="bg-white rounded-xl border border-slate-200"></div>
                <input type="hidden" id="news-contenu">
            </div>
            <div class="grid md:grid-cols-3 gap-4">
                <div>
                    <label class="block text-sm mb-1 text-slate-700">Pourquoi cette actualite ?</label>
                    <textarea id="news-faq-1" class="w-full border border-slate-300 rounded-xl px-3 py-2 focus:ring-2 focus:ring-blue-300 focus:border-blue-500" rows="3"></textarea>
                </div>
                <div>
                    <label class="block text-sm mb-1 text-slate-700">Ce que vous pouvez faire :</label>
                    <textarea id="news-faq-2" class="w-full border border-slate-300 rounded-xl px-3 py-2 focus:ring-2 focus:ring-blue-300 focus:border-blue-500" rows="3"></textarea>
                </div>
                <div>
                    <label class="block text-sm mb-1 text-slate-700">Conseil Pratique</label>
                    <textarea id="news-faq-3" class="w-full border border-slate-300 rounded-xl px-3 py-2 focus:ring-2 focus:ring-blue-300 focus:border-blue-500" rows="3"></textarea>
                </div>
            </div>
            <div class="flex justify-end gap-2 pt-2">
                <button type="button" id="close-news-modal" class="px-4 py-2 rounded-xl bg-slate-200 text-slate-700 hover:bg-slate-300">Annuler</button>
                <button type="submit" class="px-4 py-2 rounded-xl bg-blue-600 text-white hover:bg-blue-700 shadow">Enregistrer</button>
            </div>
        </form>
    </div>
</div>

<div id="delete-news-modal" class="hidden fixed inset-0 bg-black/50 z-50 items-center justify-center p-4">
    <div class="bg-white rounded-xl shadow-lg w-full max-w-md p-6">
        <h2 class="text-xl font-semibold mb-3">Supprimer cette actualite ?</h2>
        <p class="text-gray-600 mb-4">Cette action est irreversible.</p>
        <div class="flex justify-end gap-2">
            <button id="cancel-delete-news" class="px-4 py-2 rounded bg-gray-200">Annuler</button>
            <button id="confirm-delete-news" class="px-4 py-2 rounded bg-red-600 text-white">Supprimer</button>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script src="https://cdn.jsdelivr.net/npm/quill@1.3.7/dist/quill.min.js"></script>
<script src="{{ asset('assets/js/admin_actualites.js') }}"></script>
{% endblock %}
