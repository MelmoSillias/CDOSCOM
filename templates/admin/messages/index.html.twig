{% extends 'layout.html.twig' %}

{% block title %}Messages - {{ parent() }}{% endblock %}

{% block stylesheets %}
{{ parent() }}
{% endblock %}

{% block body %}
<div class="p-6">
    <h1 class="text-2xl font-bold mb-6">Gestion des Messages</h1>

    <!-- Messages Table -->
    <div class="bg-white rounded-lg shadow overflow-hidden">
        <div class="p-6 border-b border-gray-200 bg-gradient-to-r from-blue-50 to-indigo-50">
            <h2 class="text-2xl font-bold text-gray-800">Messages</h2>
            <p class="text-sm text-gray-600 mt-1">Gérez les messages de contact et rendez-vous</p>
        </div>
        <div class="p-6 overflow-x-auto">
            <div class="mb-4 md:hidden">
                <p class="text-sm text-gray-600 flex items-center">
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18"></path>
                    </svg>
                    Faites défiler horizontalement pour voir toutes les colonnes
                </p>
            </div>
            <table id="messages-table" class="w-full text-base text-left border-collapse min-w-[800px]">
                <thead class="text-sm text-gray-800 uppercase bg-gradient-to-r from-blue-50 to-indigo-50 border-b-2 border-blue-200">
                    <tr>
                        <th class="px-4 md:px-8 py-4 font-semibold text-blue-900">ID</th>
                        <th class="px-4 md:px-8 py-4 font-semibold text-blue-900">Nom</th>
                        <th class="px-4 md:px-8 py-4 font-semibold text-blue-900 hidden sm:table-cell">Email</th>
                        <th class="px-4 md:px-8 py-4 font-semibold text-blue-900 hidden md:table-cell">Téléphone</th>
                        <th class="px-4 md:px-8 py-4 font-semibold text-blue-900">Type</th>
                        <th class="px-4 md:px-8 py-4 font-semibold text-blue-900">Statut</th>
                        <th class="px-4 md:px-8 py-4 font-semibold text-blue-900">Mail</th>
                        <th class="px-4 md:px-8 py-4 font-semibold text-blue-900 hidden lg:table-cell">Date</th>
                        <th class="px-4 md:px-8 py-4 font-semibold text-blue-900">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-200">
                </tbody>
            </table>
            <div id="pagination-container" class="mt-6"></div>
        </div>

        <div class="bg-white rounded-lg shadow p-6 mt-6">
            <h2 class="text-lg font-semibold mb-4">Filtres</h2>
            <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Type</label>
                    <select id="filter-type" class="w-full border border-gray-300 rounded-md px-3 py-2">
                        <option value="">Tous</option>
                        <option value="contact">Contact</option>
                        <option value="appointment">Rendez-vous</option>
                    </select>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Statut</label>
                    <select id="filter-status" class="w-full border border-gray-300 rounded-md px-3 py-2">
                        <option value="">Tous</option>
                        <option value="unread">Non lu</option>
                        <option value="read">Vu non répondu</option>
                        <option value="responded">Répondu</option>
                    </select>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Date de début</label>
                    <input type="date" id="filter-date-start" class="w-full border border-gray-300 rounded-md px-3 py-2">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Date de fin</label>
                    <input type="date" id="filter-date-end" class="w-full border border-gray-300 rounded-md px-3 py-2">
                </div>
            </div>
            <div class="mt-4 flex flex-col sm:flex-row gap-4">
                <button id="apply-filters" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-2 rounded-lg transition-colors duration-200 shadow-sm hover:shadow-md font-medium">Appliquer les filtres</button>
                <button id="reset-filters" class="bg-gray-500 hover:bg-gray-600 text-white px-6 py-2 rounded-lg transition-colors duration-200 shadow-sm hover:shadow-md font-medium">Réinitialiser</button>
            </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6 mt-6">
            <div class="rounded-xl shadow p-5 bg-gradient-to-br from-blue-50 to-blue-100 border border-blue-200">
                <p class="text-sm font-semibold text-blue-700">Total Messages</p>
                <p id="stat-total" class="text-3xl font-bold text-blue-950 mt-2">{{ totalMessages }}</p>
            </div>
            <div class="rounded-xl shadow p-5 bg-gradient-to-br from-rose-50 to-rose-100 border border-rose-200">
                <p class="text-sm font-semibold text-rose-700">Messages Non Lus</p>
                <p id="stat-unread" class="text-3xl font-bold text-rose-950 mt-2">{{ unreadMessages }}</p>
            </div>
            <div class="rounded-xl shadow p-5 bg-gradient-to-br from-amber-50 to-amber-100 border border-amber-200">
                <p class="text-sm font-semibold text-amber-700">Messages Vus Non Répondus</p>
                <p id="stat-read" class="text-3xl font-bold text-amber-950 mt-2">{{ readMessages }}</p>
            </div>
            <div class="rounded-xl shadow p-5 bg-gradient-to-br from-emerald-50 to-emerald-100 border border-emerald-200">
                <p class="text-sm font-semibold text-emerald-700">Messages Répondus</p>
                <p id="stat-responded" class="text-3xl font-bold text-emerald-950 mt-2">{{ respondedMessages }}</p>
            </div>
        </div>
    </div>
</div>

<!-- Modals -->
<!-- Details Modal -->
<div id="details-modal" class="fixed inset-0 bg-slate-950/55 overflow-y-auto h-full w-full hidden z-50">
    <div class="relative top-14 mx-auto p-0 border border-slate-200 w-11/12 md:w-3/4 lg:w-1/2 shadow-2xl rounded-2xl bg-white">
        <div class="mt-3">
            <div class="flex items-center justify-between mb-4 px-6 pt-6">
                <h3 class="text-lg font-semibold text-slate-900">Détails du Message</h3>
                <button id="close-details-modal" class="text-gray-400 hover:text-gray-600">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                </button>
            </div>
            <div id="message-details" class="text-sm text-gray-600 px-6">
                <!-- Details will be loaded here -->
            </div>
            <div class="flex justify-end mt-4 px-6 pb-6">
                <button id="close-details-modal-btn" class="px-4 py-2 bg-slate-700 text-white rounded-lg hover:bg-slate-800">Fermer</button>
            </div>
        </div>
    </div>
</div>

<!-- Reply Modal -->
<div id="reply-modal" class="fixed inset-0 bg-slate-950/55 overflow-y-auto h-full w-full hidden z-50">
    <div class="relative top-14 mx-auto p-0 border border-slate-200 w-11/12 md:w-3/4 lg:w-1/2 shadow-2xl rounded-2xl bg-white">
        <div class="mt-3">
            <div class="flex items-center justify-between mb-4 px-6 pt-6">
                <h3 class="text-lg font-semibold text-slate-900">Répondre au Message</h3>
                <button id="close-reply-modal" class="text-gray-400 hover:text-gray-600">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                </button>
            </div>
            <div id="reply-message-details" class="mb-4 mx-6 p-4 bg-blue-50 rounded-xl border border-blue-100">
                <!-- Message details will be loaded here -->
            </div>
            <form id="reply-form" class="px-6 pb-6">
                <div class="mb-4">
                    <label for="reply-subject" class="block text-sm font-medium text-gray-700">Sujet</label>
                    <input type="text" id="reply-subject" name="subject" class="mt-1 block w-full border border-slate-300 rounded-xl px-3 py-2 shadow-sm focus:ring-2 focus:ring-blue-300 focus:border-blue-500" required>
                </div>
                <div class="mb-4">
                    <label for="reply-message" class="block text-sm font-medium text-gray-700">Message</label>
                    <textarea id="reply-message" name="message" rows="6" class="mt-1 block w-full border border-slate-300 rounded-xl px-3 py-2 shadow-sm focus:ring-2 focus:ring-blue-300 focus:border-blue-500" required></textarea>
                </div>
                <div class="flex justify-end space-x-2">
                    <button type="button" id="close-reply-modal-btn" class="bg-slate-200 text-slate-700 px-4 py-2 rounded-xl hover:bg-slate-300">Annuler</button>
                    <button type="submit" class="bg-blue-600 text-white px-4 py-2 rounded-xl hover:bg-blue-700">Envoyer</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div id="delete-modal" class="fixed inset-0 bg-slate-950/55 overflow-y-auto h-full w-full hidden z-50">
    <div class="relative top-20 mx-auto p-6 border border-slate-200 w-96 shadow-2xl rounded-2xl bg-white">
        <div class="mt-3">
            <h3 class="text-lg font-semibold text-slate-900 mb-4">Confirmer la suppression</h3>
            <p class="text-sm text-gray-600 mb-4">Êtes-vous sûr de vouloir supprimer ce message ? Cette action est irréversible.</p>
            <div class="flex justify-end space-x-2">
                <button id="cancel-delete" class="bg-slate-200 text-slate-700 px-4 py-2 rounded-xl hover:bg-slate-300">Annuler</button>
                <button id="confirm-delete" class="bg-red-600 text-white px-4 py-2 rounded-xl hover:bg-red-700">Supprimer</button>
            </div>
        </div>
    </div>
</div>

{% endblock %}

{% block javascripts %}
{{ parent() }}
<script src="{{ asset('assets/js/admin_messages.js') }}"></script>
{% endblock %}