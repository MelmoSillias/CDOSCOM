<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>{% block title %}Panneau d'administration{% endblock %}</title>

  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  <script src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js" defer></script>

  {% block stylesheets %}{% endblock %}
</head>

<body class="bg-slate-100">

<div class="min-h-screen flex flex-col">

  <!-- NAVBAR -->
  <nav class="bg-gray-800 text-white" x-data="{ mobileOpen: false }">
    <div class="mx-auto max-w-7xl px-4">
      <div class="flex h-16 items-center justify-between">

        <!-- Logo -->
        <div class="flex items-center gap-3">
          <img src="{{ asset('assets/img/logoCDOS.png') }}" class="h-8" alt="Logo">
        </div>

        <!-- Desktop menu -->
        <div class="hidden sm:flex items-center gap-2">

          {% set linkBase = 'px-3 py-2 rounded-md text-sm font-medium transition' %}

          <a href="{{ path('admin_dashboard') }}"
             aria-current="{{ active_page == 'dashboard' ? 'page' : false }}"
             class="{{ linkBase }}
             {{ active_page == 'dashboard'
                ? 'bg-gray-900 text-white'
                : 'text-gray-300 hover:bg-white/10 hover:text-white' }}">
            Dashboard
          </a>

          <a href="{{ path('admin_messages') }}"
             aria-current="{{ active_page == 'messages' ? 'page' : false }}"
             class="{{ linkBase }} relative
             {{ active_page == 'messages'
                ? 'bg-gray-900 text-white'
                : 'text-gray-300 hover:bg-white/10 hover:text-white' }}">
            Messages
            <span id="messages-badge"
                  class="absolute -top-1 -right-1 hidden h-5 w-5 rounded-full bg-red-500 text-xs flex items-center justify-center">
              0
            </span>
          </a>

           <a href="{{ path('admin_actualites') }}"
             aria-current="{{ active_page == 'actualites' ? 'page' : false }}"
             class="{{ linkBase }}
             {{ active_page == 'actualites'
               ? 'bg-gray-900 text-white'
               : 'text-gray-300 hover:bg-white/10 hover:text-white' }}">
            Actualites
           </a>

           <a href="{{ path('admin_personnels') }}"
             aria-current="{{ active_page == 'personnels' ? 'page' : false }}"
             class="{{ linkBase }}
             {{ active_page == 'personnels'
               ? 'bg-gray-900 text-white'
               : 'text-gray-300 hover:bg-white/10 hover:text-white' }}">
            Personnels
           </a>

           <a href="{{ path('admin_configurations') }}"
             aria-current="{{ active_page == 'configurations' ? 'page' : false }}"
             class="{{ linkBase }}
             {{ active_page == 'configurations'
               ? 'bg-gray-900 text-white'
               : 'text-gray-300 hover:bg-white/10 hover:text-white' }}">
            Configurations
           </a>
 
        </div>

        <!-- Right actions -->
        <div class="flex items-center gap-3">

          <!-- Notifications -->
          <button class="p-1 rounded-full text-gray-300 hover:text-white focus:outline-none">
            <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.5"
                 viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round"
                    d="M14.857 17.082a23.848 23.848 0 0 0 5.454-1.31
                    A8.967 8.967 0 0 1 18 9.75V9A6 6 0 0 0 6 9v.75
                    a8.967 8.967 0 0 1-2.312 6.022
                    c1.733.64 3.56 1.085 5.455 1.31
                    m5.714 0a24.255 24.255 0 0 1-5.714 0
                    m5.714 0a3 3 0 1 1-5.714 0"/>
            </svg>
          </button>

          <!-- Profile -->
          <div class="relative" x-data="{ open:false }">
            <button @click="open = !open" class="flex rounded-full focus:outline-none">
              <img class="h-8 w-8 rounded-full"
                   src="https://images.unsplash.com/photo-1472099645785-5658abf4ff4e"
                   alt="Profil">
            </button>

            <div x-show="open"
                 @click.outside="open=false"
                 x-transition
                 class="absolute right-0 mt-2 w-44 bg-white rounded-md shadow-lg py-1 text-gray-700">
              <a href="#" class="block px-4 py-2 text-sm hover:bg-gray-100">Profil</a>
              <a href="#" class="block px-4 py-2 text-sm hover:bg-gray-100">Paramètres</a>
              <a href="{{ path('app_logout') }}"
                 class="block px-4 py-2 text-sm hover:bg-gray-100">Déconnexion</a>
            </div>
          </div>

          <!-- Mobile toggle -->
          <button @click="mobileOpen = !mobileOpen"
                  class="sm:hidden p-2 rounded-md text-gray-300 hover:text-white">
            ☰
          </button>
        </div>

      </div>
    </div>

    <!-- Mobile menu -->
    <div x-show="mobileOpen" x-transition class="sm:hidden bg-white text-gray-800 shadow-md">
      <div class="space-y-1 px-3 py-3">

        {% set mobileBase = 'block px-3 py-2 rounded-md font-medium' %}

        <a href="{{ path('admin_dashboard') }}"
           class="{{ mobileBase }}
           {{ active_page == 'dashboard'
              ? 'bg-gray-900 text-white'
              : 'hover:bg-gray-100' }}">
          Dashboard
        </a>

        <a href="{{ path('admin_messages') }}"
           class="{{ mobileBase }}
           {{ active_page == 'messages'
              ? 'bg-gray-900 text-white'
              : 'hover:bg-gray-100' }}">
          Messages
        </a>
          <a href="{{ path('admin_actualites') }}"
            class="{{ mobileBase }}
            {{ active_page == 'actualites'
              ? 'bg-gray-900 text-white'
              : 'hover:bg-gray-100' }}">Actualites</a>
          <a href="{{ path('admin_personnels') }}"
            class="{{ mobileBase }}
            {{ active_page == 'personnels'
              ? 'bg-gray-900 text-white'
              : 'hover:bg-gray-100' }}">Personnels</a>
          <a href="{{ path('admin_configurations') }}"
            class="{{ mobileBase }}
            {{ active_page == 'configurations'
              ? 'bg-gray-900 text-white'
              : 'hover:bg-gray-100' }}">Configurations</a>
      </div>
    </div>
  </nav>

  <!-- MAIN -->
  <main class="flex-1 p-4 md:p-6">
    {% block body %}{% endblock %}
  </main>

</div>

{% block javascripts %}
<script>
document.addEventListener('DOMContentLoaded', () => {
  fetch('/api/messages/count?status=pending')
    .then(r => r.json())
    .then(data => {
      const badge = document.getElementById('messages-badge');
      if (data?.count > 0) {
        badge.textContent = data.count > 99 ? '99+' : data.count;
        badge.classList.remove('hidden');
      }
    });
});
</script>
{% endblock %}

</body>
</html>
