{% extends 'base.html.twig' %}

{% block title %}{{ service.title }} | Service dentaire{% endblock %}

{% block meta_description %}Informations sur {{ service.title|lower }}: indications, deroulement du soin, recommandations et accompagnement au cabinet dentaire Ousmane Sow.{% endblock %}

{% block structured_data %}
    {{ parent() }}
    {% set breadcrumbSchema = {
        '@context': 'https://schema.org',
        '@type': 'BreadcrumbList',
        'itemListElement': [
            {
                '@type': 'ListItem',
                'position': 1,
                'name': 'Accueil',
                'item': absolute_url(path('app_home'))
            },
            {
                '@type': 'ListItem',
                'position': 2,
                'name': 'Services',
                'item': absolute_url(path('services_index'))
            },
            {
                '@type': 'ListItem',
                'position': 3,
                'name': service.title,
                'item': absolute_url(path('service_show', {'slug': slug}))
            }
        ]
    } %}
    {% set serviceSchema = {
        '@context': 'https://schema.org',
        '@type': 'Service',
        'name': service.title,
        'description': block('meta_description')|striptags|trim,
        'serviceType': service.title,
        'provider': {
            '@type': 'Dentist',
            'name': 'Cabinet dentaire Ousmane Sow',
            'url': absolute_url(path('app_home'))
        },
        'areaServed': {
            '@type': 'City',
            'name': 'Bamako'
        },
        'url': absolute_url(path('service_show', {'slug': slug}))
    } %}
    <script type="application/ld+json">{{ breadcrumbSchema|json_encode(constant('JSON_UNESCAPED_SLASHES'))|raw }}</script>
    <script type="application/ld+json">{{ serviceSchema|json_encode(constant('JSON_UNESCAPED_SLASHES'))|raw }}</script>
{% endblock %}

{% block body %}
<section class="py-16 bg-white">
    <div class="container mx-auto px-6 md:px-12">
        <div class="mb-8">
            <a href="{{ path('services_index') }}" class="text-blue-700 hover:text-blue-500 font-semibold">← Retour aux services</a>
        </div>
        <div class="max-w-5xl mx-auto space-y-6">
            <div class="text-center">
                <p class="text-sm uppercase tracking-[0.3em] text-blue-500 mb-3">Service</p>
                <h1 class="text-3xl font-bold text-blue-900">{{ service.title }}</h1>
            </div>
            <div class="bg-blue-50 rounded-2xl p-6">
                <p class="text-gray-700">Parcourez le détail du service : protocole, indications, durée, soins associés et recommandations post-acte.</p>
            </div>
            <div class="space-y-8">
                {% include service.partial %}

                <div class="grid md:grid-cols-3 gap-4">
                    <div class="bg-white border border-blue-100 rounded-xl p-4 shadow-sm">
                        <p class="text-xs uppercase tracking-[0.2em] text-blue-500">Durée</p>
                        <p class="text-lg font-semibold text-blue-900">Selon l'acte (30-90 min)</p>
                        <p class="text-gray-600 text-sm">Prévoyez une marge de 10 minutes pour l'accueil et les consignes post-soins.</p>
                    </div>
                    <div class="bg-white border border-blue-100 rounded-xl p-4 shadow-sm">
                        <p class="text-xs uppercase tracking-[0.2em] text-blue-500">Confort</p>
                        <p class="text-lg font-semibold text-blue-900">Anesthésie adaptée</p>
                        <p class="text-gray-600 text-sm">Techniques locales indolores, options d'accompagnement pour les patients anxieux.</p>
                    </div>
                    <div class="bg-white border border-blue-100 rounded-xl p-4 shadow-sm">
                        <p class="text-xs uppercase tracking-[0.2em] text-blue-500">Suivi</p>
                        <p class="text-lg font-semibold text-blue-900">Contrôle inclus</p>
                        <p class="text-gray-600 text-sm">Un rendez-vous de contrôle est prévu pour vérifier la cicatrisation et les ajustements.</p>
                    </div>
                </div>

                <div class="bg-white border border-gray-100 rounded-2xl p-6 shadow-sm">
                    <h2 class="text-2xl font-bold text-blue-900 mb-4">Questions fréquentes</h2>
                    <dl class="space-y-4 text-gray-700">
                        <div>
                            <dt class="font-semibold text-blue-800">Faut-il arrêter de manger avant de venir ?</dt>
                            <dd>Pour la plupart des actes, un repas léger est conseillé. Évitez café et tabac juste avant.</dd>
                        </div>
                        <div>
                            <dt class="font-semibold text-blue-800">Puis-je conduire après l'acte ?</dt>
                            <dd>Oui pour une anesthésie locale simple. En cas de prémédication sédative, faites-vous raccompagner.</dd>
                        </div>
                        <div>
                            <dt class="font-semibold text-blue-800">Que faire en cas de gêne après ?</dt>
                            <dd>Utilisez les antalgiques prescrits et appliquez du froid local si indiqué. Contactez-nous si la douleur persiste au-delà de 48h.</dd>
                        </div>
                    </dl>
                </div>

                <div class="flex flex-col md:flex-row items-center justify-between gap-4 bg-blue-800 text-white rounded-2xl p-6 shadow">
                    <div>
                        <p class="text-sm uppercase tracking-[0.2em] text-blue-100">Prendre rendez-vous</p>
                        <h3 class="text-2xl font-bold">Planifiez ce soin dès maintenant</h3>
                        <p class="text-blue-100">Nous vous aiderons à préparer la séance et à choisir le créneau adapté.</p>
                    </div>
                    <a href="#contact" class="px-5 py-3 bg-white text-blue-900 font-semibold rounded-lg hover:bg-blue-50 transition shadow">Contact</a>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
