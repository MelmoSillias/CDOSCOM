{% extends 'base.html.twig' %}

{% block title %}Services dentaires | Cabinet dentaire Ousmane Sow{% endblock %}

{% block meta_description %}Decouvrez tous nos services dentaires: soins, extractions, protheses, radiographie, esthetique et prise en charge pediatrique a Bamako.{% endblock %}

{% block body %}
<section class="py-16 bg-blue-50">
    <div class="container mx-auto px-6 md:px-12">
        <div class="text-center mb-10">
            <p class="text-sm uppercase tracking-[0.3em] text-blue-500 mb-3">Services</p>
            <h1 class="text-3xl font-bold text-blue-900 mb-2">Tous nos services</h1>
            <p class="text-gray-600 max-w-3xl mx-auto">Sélectionnez un service pour voir le détail complet.</p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {% for slug, service in services %}
                <a href="{{ path('service_show', { slug }) }}" class="block bg-white rounded-xl shadow-md border border-gray-100 p-6 hover:border-blue-200 transition">
                    <div class="flex items-center justify-between mb-3">
                        <h2 class="text-xl font-semibold text-blue-900">{{ service.title }}</h2>
                        <span class="text-blue-700 text-sm">Voir</span>
                    </div>
                    <p class="text-gray-600 text-sm">Détail, protocole, durée et recommandations.</p>
                </a>
            {% endfor %}
        </div>
    </div>
</section>
{% endblock %}
